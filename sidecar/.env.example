# 主 LLM provider（任意 OpenAI 兼容端点）。任选其一，取消注释填入。
# 旧名 YIBAO_GLM_* 仍向后兼容（作为回退）。

# —— 智谱 GLM（项目原生；支持视觉 computer-use 兜底）——
YIBAO_LLM_API_KEY=your_zhipu_api_key_here
YIBAO_LLM_MODEL=glm-4.6
# YIBAO_LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/

# —— DeepSeek（OpenAI 兼容；支持流式 + function calling，无视觉模型）——
# YIBAO_LLM_API_KEY=sk-your_deepseek_key
# YIBAO_LLM_MODEL=deepseek-chat
# YIBAO_LLM_BASE_URL=https://api.deepseek.com
