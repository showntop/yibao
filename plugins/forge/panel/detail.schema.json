{
  "version": 1,
  "type": "detail",
  "fields": [
    {"label": "标题", "value": "$data.rows.0.title"},
    {"label": "痛点", "value": "$data.rows.0.pain"},
    {"label": "谁有", "value": "$data.rows.0.who"},
    {"label": "状态", "value": "$data.rows.0.status"},
    {"label": "快筛结论", "value": "$data.rows.0.triage"},
    {"label": "裁决理由", "value": "$data.rows.0.verdict_reason"},
    {"label": "挑战文档", "value": "$data.rows.0.challenge_path"},
    {"label": "PRD", "value": "$data.rows.0.prd_path"},
    {"label": "原型", "value": "$data.rows.0.proto_path"},
    {"label": "创建", "value": "$data.rows.0.created_at|date"},
    {"label": "更新", "value": "$data.rows.0.updated_at|date"}
