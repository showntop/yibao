  "actions": [
    {"label": "挑战", "method": "forge.challenge", "params": {"id": "$data.rows.0.id", "title": "$data.rows.0.title"}},
    {"label": "竞品扫描", "method": "forge.scan", "params": {"id": "$data.rows.0.id", "title": "$data.rows.0.title"}},
    {"label": "出 PRD", "method": "forge.prd", "params": {"id": "$data.rows.0.id", "title": "$data.rows.0.title"}},
    {"label": "出原型", "method": "forge.proto", "params": {"id": "$data.rows.0.id", "title": "$data.rows.0.title"}},
    {"label": "裁决", "method": "forge.verdict_form", "params": {"id": "$data.rows.0.id"}},
    {"label": "删除", "method": "forge.delete", "params": {"id": "$data.rows.0.id"}}
  ]
